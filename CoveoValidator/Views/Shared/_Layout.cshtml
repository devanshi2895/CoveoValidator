<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coveo GA Validator</title>

    <!-- Bootstrap 5 CDN -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        body { background-color: #f0f2f5; }

        /* ── Navbar ── */
        .navbar-brand { font-weight: 700; letter-spacing: 0.5px; }

        /* ── Search card ── */
        .search-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,.08);
        }

        /* ── Result accordion ── */
        .accordion-button { font-weight: 600; }
        .accordion-button:not(.collapsed) { background-color: #e7f1ff; }

        /* ── Field badge pills ── */
        .badge-valid   { background-color: #198754; color: #fff; }
        .badge-empty   { background-color: #fd7e14; color: #fff; }
        .badge-missing { background-color: #dc3545; color: #fff; }

        /* ── Field list items ── */
        .field-valid   { border-left: 4px solid #198754; }
        .field-empty   { border-left: 4px solid #fd7e14; }
        .field-missing { border-left: 4px solid #dc3545; }

        /* ── Loader overlay ── */
        #loader {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 9999;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.2rem;
            gap: 16px;
        }
        #loader.show { display: flex; }

        /* ── Summary bar ── */
        .summary-bar { font-size: .85rem; }

        /* ── Metadata chips ── */
        .meta-chip {
            display: inline-block;
            background: #e9ecef;
            border-radius: 20px;
            padding: 2px 10px;
            font-size: .78rem;
            font-family: monospace;
        }

        /* ── No-results ── */
        .no-results-icon { font-size: 3rem; color: #adb5bd; }
    </style>
</head>
<body>

    <!-- ── Navbar ── -->
    <nav class="navbar navbar-dark bg-primary shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-shield-check me-2"></i>Coveo GA Validator
            </a>
            <span class="text-white-50 small">Sitecore ↔ Coveo Content Checker</span>
        </div>
    </nav>

    <!-- ── Loader overlay ── -->
    <div id="loader">
        <div class="spinner-border text-light" role="status" style="width:3rem;height:3rem;">
            <span class="visually-hidden">Loading…</span>
        </div>
        <div>Querying Coveo API, please wait…</div>
    </div>

    <!-- ── Main content ── -->
    <main class="container py-4">
        @RenderBody()
    </main>

    <!-- ── Footer ── -->
    <footer class="text-center text-muted py-3 small border-top bg-white">
        Coveo GA Validator &copy; @DateTime.Now.Year  YasConnect Platform Team
    </footer>

    <!-- Bootstrap 5 JS bundle (includes Popper) — no SRI so hash mismatches never silently block load -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Loader trigger -->
    <script>
        document.getElementById('searchForm')?.addEventListener('submit', function () {
            document.getElementById('loader').classList.add('show');
        });
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>
